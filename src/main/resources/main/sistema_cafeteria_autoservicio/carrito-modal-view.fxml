<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="main.sistema_cafeteria_autoservicio.Controllers.CarritoModalController"
            style="-fx-background-color: #f1f5f9;"
            prefHeight="560.0" prefWidth="760.0">

    <top>
        <HBox spacing="10.0" style="-fx-background-color: #0f172a;" BorderPane.alignment="CENTER">
            <padding>
                <Insets top="12.0" right="14.0" bottom="12.0" left="14.0"/>
            </padding>
            <Label text="Carrito de compra" style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="Cerrar" onAction="#handleCerrar" style="-fx-background-color: #334155; -fx-text-fill: white;"/>
        </HBox>
    </top>

    <center>
        <VBox spacing="10.0">
            <padding>
                <Insets top="12.0" right="14.0" bottom="12.0" left="14.0"/>
            </padding>

            <ScrollPane fitToWidth="true" hbarPolicy="NEVER" VBox.vgrow="ALWAYS">
                <content>
                    <VBox fx:id="lineasCarritoBox" spacing="8.0"/>
                </content>
            </ScrollPane>

            <Label fx:id="estadoLabel" text="Cargando carrito..." style="-fx-text-fill: #475569;"/>

            <VBox spacing="8.0" style="-fx-background-color: #e2e8f0; -fx-background-radius: 8;">
                <padding>
                    <Insets top="10.0" right="10.0" bottom="10.0" left="10.0"/>
                </padding>
                <Label text="Pago" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #0f172a;"/>
                <HBox spacing="8.0" alignment="CENTER_LEFT">
                    <Label text="Metodo:" style="-fx-text-fill: #334155;"/>
                    <ComboBox fx:id="metodoPagoCombo" prefWidth="220.0" promptText="Selecciona metodo"/>
                    <Label text="Referencia:" style="-fx-text-fill: #334155;"/>
                    <TextField fx:id="referenciaField" promptText="Opcional" HBox.hgrow="ALWAYS"/>
                    <Button fx:id="checkoutButton" text="Checkout" onAction="#handleCheckout" style="-fx-background-color: #16a34a; -fx-text-fill: white; -fx-font-weight: bold;"/>
                </HBox>
            </VBox>
        </VBox>
    </center>

    <bottom>
        <HBox spacing="20.0" style="-fx-background-color: #e2e8f0;" BorderPane.alignment="CENTER_LEFT">
            <padding>
                <Insets top="10.0" right="14.0" bottom="10.0" left="14.0"/>
            </padding>
            <Label fx:id="itemsLabel" text="Items: 0" style="-fx-text-fill: #0f172a; -fx-font-size: 14px;"/>
            <Label fx:id="totalLabel" text="Total a pagar: $0.00" style="-fx-text-fill: #be123c; -fx-font-size: 16px; -fx-font-weight: bold;"/>
        </HBox>
    </bottom>
</BorderPane>

